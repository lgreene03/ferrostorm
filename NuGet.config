<?xml version="1.0" encoding="utf-8"?>
<!-- Offline-first: the sim, tools, and tests build with zero package
     dependencies by design (ADR-002 spirit). Only /game (Godot) needs
     nuget.org, and it is built on dev machines, not in CI. -->
<configuration>
  <packageSources>
    <clear />
  </packageSources>
</configuration>
