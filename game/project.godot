; Project SLAGLINE - Godot 4 presentation layer (TICKET-P1-07).
; The renderer consumes sim snapshots only (ADR-001); it never touches live state.

config_version=5

[application]
config/name="Ferrostorm (working title)"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[dotnet]
project/assembly_name="Ferrostorm.Game"

[gui]
theme/custom_font="res://ui/fonts/SairaCondensed-SemiBold.ttf"

[display]
window/size/viewport_width=1600
window/size/viewport_height=900

[rendering]
renderer/rendering_method="forward_plus"
environment/volumetric_fog/volume_size=96
environment/volumetric_fog/volume_depth=96
environment/volumetric_fog/use_filter=1
lights_and_shadows/directional_shadow/size=4096
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
anti_aliasing/quality/msaa_3d=2

