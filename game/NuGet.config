<?xml version="1.0" encoding="utf-8"?>
<!-- Overrides the repo-root NuGet.config (which clears all sources for the
     offline-first sim). /game is the one project that needs nuget.org, for
     Godot.NET.Sdk and GodotSharp - NuGet.config resolution stops at the
     nearest config found walking up from the build directory, so this file
     shadows the root one for anything built from within game/. -->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
